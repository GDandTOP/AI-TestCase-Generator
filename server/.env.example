# ============================================
# TestPlanner 서버 환경 변수 예시
# 이 파일을 복사하여 .env 파일을 만드세요:
#   cp server/.env.example server/.env
# ============================================

# KT AI Codi API 키 (필수)
CODI_API_KEY=your_codi_api_key_here

# KT AI Codi API 엔드포인트
CODI_API_BASE_URL=https://api.codi.kt.co.kr/v1

# Anthropic Claude API 키 (선택 - Codi 사용 시 비워도 됩니다)
ANTHROPIC_API_KEY=

# 서버 기본 설정
PORT=3000
NODE_ENV=development
